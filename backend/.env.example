# Ejemplo de variables de entorno para CliniData (backend)
# Copiar a .env y completar valores seguros antes de ejecutar

NODE_ENV=development
PORT=3000
# Base de datos SQLite (archivo local)
DATABASE_URL="file:./dev.db"

# JWT secret (usar un valor fuerte en producción, por ejemplo 32+ chars random)
JWT_SECRET="change_this_to_a_strong_secret"

# Clave de cifrado para AES-256-GCM.
# Puede ser 64 hex chars (32 bytes) o cualquier passphrase que será derivada con scrypt.
ENCRYPTION_KEY="change_this_to_a_strong_hex_or_passphrase"

# Credenciales de seed (opcional)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password123

# Orígenes permitidos para CORS (coma-separados). Usar * para desarrollo
ALLOWED_ORIGINS=*
